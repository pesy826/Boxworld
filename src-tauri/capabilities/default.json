{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    "dialog:allow-save",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "http://*:*" },
        { "url": "https://*" },
        { "url": "https://*:*" }
      ]
    }
  ]
}